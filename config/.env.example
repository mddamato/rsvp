# ===== Central configuration =====
# Copy this file to config/.env on the server and fill in real values.
# config/.env is gitignored and never committed.

# Domain the app is served on (used by nginx, certbot, QR links, emails)
DOMAIN_NAME=yourdomain.com

# Flask session signing key. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

# Database (postgres image reads POSTGRES_*, app reads the same values)
POSTGRES_USER=rsvp_app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=rsvp
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# AWS
AWS_REGION=us-east-1
SES_SENDER_EMAIL=noreply@yourdomain.com
BACKUP_S3_BUCKET=your-backup-bucket-name

# Admin auth file inside the app container (mounted from config/htpasswd)
HTPASSWD_PATH=/etc/rsvp/.htpasswd

# Guest-facing page text. All optional except EVENT_TITLE has a default.
EVENT_TITLE=Our Celebration
EVENT_SUBHEADING=Saturday, June 5, 2027 at 4:00 PM
EVENT_DETAILS=Join us at the Riverside Pavilion. Parking is available in Lot B; please arrive 15 minutes early for seating.
EVENT_CLOSING=- The Smith Family
